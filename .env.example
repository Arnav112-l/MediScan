# Flask / DB
FLASK_ENV=development
SECRET_KEY=change-me
DATABASE_URL=sqlite:///medscan.db

# JWT
JWT_SECRET_KEY=change-me-too
JWT_ACCESS_MINUTES=15
JWT_REFRESH_DAYS=7

# Required for server chat /api/chatbot (+ optional lab LLM) — OpenAI-compatible API
OMNIDIMENSION_API_BASE=https://api.omnidimension.ai
OMNIDIMENSION_API_KEY=
# Model name for /v1/chat/completions (e.g. gpt-4o-mini). Not the web widget secret.
OMNIDIMENSION_MODEL=gpt-4o-mini

# Floating web widget (omnidim.io) is loaded by the *frontend* — set in frontend/.env:
#   VITE_OMNIDIMENSION_WIDGET_SECRET=<widget secret from Omnidimension>

# OCR (Windows: full path to tesseract.exe)
TESSERACT_CMD=

# Playwright: set to 1 to watch Chromium scrape (debug)
PLAYWRIGHT_HEADED=

# Google OAuth (optional)
GOOGLE_OAUTH_CLIENT_ID=

# Redis / prod cache (optional)
REDIS_URL=
