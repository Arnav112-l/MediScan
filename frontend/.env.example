# Public Vite vars only — never put Flask secrets here.

# Optional: Omnidimension floating web widget (omnidim.io)
# Get the secret from your Omnidimension dashboard; this is NOT the same as OMNIDIMENSION_MODEL
# (backend .env — that one is the chat *model name* for OpenAI-compatible APIs, e.g. gpt-4o-mini).
VITE_OMNIDIMENSION_WIDGET_SECRET=eaa54999868e2ff9856745bb52ac3b9a

# Production API base (origin only, no trailing slash, no /api path). Leave empty in dev/preview
# so requests use same-origin /api and Vite proxies to Flask (see vite.config.js).
# On Vercel, SET THIS to your Render API URL (e.g. https://mediscan-xxx.onrender.com) so the
# browser calls Render directly: avoids CDN proxy limits on long Playwright scrapes (search).
# VITE_API_URL=https://your-api.example.com

# Dev/preview only: where Vite proxies /api and /health (Flask default :5000).
# MEDSCAN_API_PROXY=http://127.0.0.1:5000

# Google Identity Services (optional, for "Continue with Google")
# VITE_GOOGLE_CLIENT_ID=
